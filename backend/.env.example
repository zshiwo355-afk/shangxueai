# MaxKB
MAXKB_BASE_URL=http://your-maxkb.example.com/api/application/<APP_ID>
MAXKB_API_KEY=
MAXKB_ADMIN_BASE_URL=
MAXKB_SYSTEM_API_KEY=
MAXKB_ADMIN_USERNAME=
MAXKB_ADMIN_PASSWORD=
MAXKB_WORKSPACE_ID=default
MAXKB_KB_ID=
MAXKB_TIMEOUT_SECONDS=60
MAXKB_RULE_TOP_K=8
MAXKB_RULE_SIMILARITY=0.3
MAXKB_KNOWLEDGE_TOP_K=12
MAXKB_KNOWLEDGE_SIMILARITY=0.3

# LLM (OpenAI 兼容协议)
LLM_BASE_URL=https://api.ofox.ai/v1
LLM_API_KEY=
LLM_MODEL=openai/gpt-4o
LLM_TIMEOUT_SECONDS=120
LLM_MAX_OUTPUT_TOKENS=4000

# CORS
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://127.0.0.1:5173,http://localhost:5173

# 工程级硬校验阈值
MIN_ROUNDS=10

# 数据库（MySQL）
DB_DSN=mysql+aiomysql://root:123@127.0.0.1:3306/shangxueai?charset=utf8mb4
DB_ECHO=false
DB_POOL_SIZE=10
DB_POOL_RECYCLE_SECONDS=1800

# 鉴权（V2 启用：管理员 + 普通用户）
AUTH_ENABLED=true
JWT_SECRET=change-me-in-production-shangxueai
JWT_ALGORITHM=HS256
JWT_TTL_HOURS=720
